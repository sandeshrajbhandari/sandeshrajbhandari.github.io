    "prompt": "{\n  \"design_system\": {\n    \"metadata\": {\n      \"style_name\": \"Whimsical Pencil Story Illustration\",\n      \"target_audience\": \"Children / Family\",\n      \"version\": \"3.0\"\n    },\n    \"visual_parameters\": {\n      \"medium\": {\n        \"primary\": \"Colored Pencil\",\n        \"application\": \"Hand-drawn\",\n        \"texture\": {\n          \"type\": \"Clearly visible pencil strokes\",\n          \"quality\": \"Soft, slightly uneven outlines\",\n          \"finish\": \"Illustrative / Non-photorealistic\"\n        }\n      },\n      \"line_work\": {\n        \"style\": \"Simple, clean outlines\",\n        \"weight\": \"Organic and slightly sketchy\",\n        \"clarity\": \"High\"\n      },\n      \"color_theory\": {\n        \"base_tone\": \"Warm and joyful\",\n        \"palette_type\": \"Soft pastel with pops of color\",\n        \"adjustments\": {\n          \"brightness\": \"High\",\n          \"saturation\": \"Balanced and friendly\",\n          \"contrast\": \"Low and gentle\"\n        }\n      },\n      \"lighting_and_shading\": {\n        \"shadows\": \"Very soft\",\n        \"highlights\": \"Gentle pencil highlights\",\n        \"rendering\": \"Flat colors with light texture\",\n        \"gradients\": \"Subtle pencil blending\"\n      }\n    },\n    \"subject_geometry\": {\n      \"anatomy\": {\n        \"proportions\": \"Semi-cartoon\",\n        \"scale\": \"Children’s storybook\"\n      },\n      \"facial_features\": {\n        \"eyes\": \"Small dot eyes\",\n        \"mouth\": \"Tiny curved smile\",\n        \"complexity\": \"Minimal and expressive\"\n      }\n    },\n    \"atmosphere\": {\n      \"mood\": [\n        \"Wholesome\",\n        \"Cozy\",\n        \"Playful\",\n        \"Comforting\"\n      ],\n      \"genre_tags\": [\n        \"Storybook Illustration\",\n        \"Children Art\",\n        \"Hand-drawn Sketch\"\n      ]\n    }\n  },\n  \"generation_configs\": {\n    \"negative_prompt_tokens\": [\n      \"