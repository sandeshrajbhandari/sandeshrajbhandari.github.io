    "prompt_en": "{\"image_description\":{\"face\":{\"preserve_original\":true,\"reference_match\":true,\"description\":\"Maintain the same facial features, natural expression, and identity from the uploaded image without altering structure or proportions.\"},\"photo_style\":{\"type\":\"natural outdoor portrait\",\"camera_angle\":\"close-up, slightly low angle\",\"lighting\":\"bright natural sunlight with warm highlights on skin\",\"mood\":\"fresh, tropical, radiant\",\"depth_of_field\":\"sharp subject, clear background\"},\"subject\":{\"pose\":\"raising one arm upward to touch the wooden roof structure, body angled slightly to the side\",\"expression\":\"soft, curious gaze looking off-camera\",\"hair\":{\"style\":\"long dark, messy hairs\",\"details\":\"tucked behind ear with a flower accessory\"},\"accessories\":{\"hair_flower\":\"large white plumeria tucked behind the ear\",\"necklace\":\"thin gold chain necklace\"},\"clothing\":{\"top_layer\":{\"type\":\"oversized beige button-up shirt\",\"details\":\"lightweight fabric, unbuttoned at the top\",\"brand_logo\":\"small embroidered Polo Ralph Lauren logo\"},\"inner_top\":{\"type\":\"animal-print crop top\",\"details\":\"visible under the open shirt\"}}},\"environment\":{\"setting\":\"tropical beach hut or seaside wooden cabana\",\"background\":[\"blue ocean water\",\"bright sky with scattered clouds\",\"distant city skyline and coastal buildings\",\"wooden beams and thatched roofing above\"],\"atmosphere\":\"sunny, warm, relaxed coastal vibe\"},\"aesthetic\":{\"style\":\"tropical vacation portrait\",\"features\":[\"sun-kissed skin\",\"soft natural blush\",\"vibrant coastal colors\",\"laid-back holiday mood\",\"clean and bright natural lighting\"]}}}",
