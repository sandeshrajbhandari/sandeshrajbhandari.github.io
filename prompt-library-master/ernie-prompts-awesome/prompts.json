    "prompt": "{\n  \"image_type\": \"photographic portrait\",\n  \"composition\": {\n    \"framing\": \"tight close-up portrait\",\n    \"crop\": \"top of head slightly cropped, face and upper neck fully visible\",\n    \"orientation\": \"vertical\",\n    \"camera_angle\": \"slightly low angle, looking up toward the subject\",\n    \"subject_position\": \"centered\",\n    \"depth_of_field\": \"shallow depth of field, background completely out of focus\"\n  },\n  \"subject\": {\n    \"gender_presentation\": \"female-presenting\",\n    \"age_range_visible\": \"young adult\",\n    \"skin_tone\": \"fair/light skin tone\",\n    \"skin_texture\": \"natural skin texture visible, smooth with subtle highlights\",\n    \"facial_features\": {\n      \"face_shape\": \"oval\",\n      \"forehead\": \"partially visible, softly lit\",\n      \"eyebrows\": \"medium thickness, natural shape, brown\",\n      \"eyes\": {\n        \"color\": \"light-colored (appears green or hazel)\",\n        \"shape\": \"almond-shaped\",\n        \"expression\": \"relaxed, neutral gaze directed slightly downward toward camera\"\n      },\n      \"nose\": \"straight, proportionate\",\n      \"lips\": {\n        \"shape\": \"full\",\n        \"state\": \"slightly parted\",\n        \"finish\": \"glossy\"\n      }\n    },\n    \"expression\": \"calm, composed, neutral\"\n  },\n  \"hair\": {\n    \"color\": \"light brown with warm highlights\",\n    \"texture\": \"curly / wavy\",\n    \"style\": \"loose curls framing the face\",\n    \"movement\": \"some strands lifted or displaced, suggesting wind or motion\",\n    \"parting\": \"no clear defined part visible\"\n  },\n  \"attire\": {\n    \"garment_type\": \"high-neck top\",\n    \"neckline\": \"turtleneck / mock neck\",\n    \"fit\": \"close-fitting around neck\",\n    \"pattern\": \"ornate floral or baroque-style pattern\",\n    \"colors\": [\n      \"deep red\",\n      \"white\"\n    ],\n    \"fabric_appearance\": \"smooth, structured textile\"\n  },\n  \"accessories\": {\n    \"jewelry\": \"none visible\",\n    \"eyewear\": \"none\",\n    \"headwear\": \"none\"\n  },\n  \"lighting\": {\n    \"light_source\": \"natural sunlight\",\n    \"direction\": \"strong side lighting from upper left\",\n    \"contrast\": \"high contrast between lit and shadowed areas\",\n    \"highlights\": \"pronounced highlights on cheekbones, nose bridge, lips\",\n    \"shadows\": \"soft shadow across right side of face\"\n  },\n  \"background\": {\n    \"environment\": \"outdoor setting\",\n    \"background_color\": \"solid blue\",\n    \"detail_level\": \"no visible objects or textures\",\n    \"blur\": \"completely blurred / smooth\"\n  },\n  \"color_grading\": {\n    \"overall_tone\": \"natural, warm\",\n    \"skin_color_balance\": \"warm highlights with neutral shadows\",\n    \"saturation\": \"moderate\"\n  },\n  \"image_quality\": {\n    \"sharpness\": \"high facial detail\",\n    \"texture_detail\": \"visible skin highlights and hair strands\",\n    \"noise\": \"minimal\",\n    \"realism\": \"photorealistic\"\n  },\n  \"mood_and_style\": {\n    \"mood\": \"serene, editorial\",\n    \"style\": \"fashion/editorial portrait\",\n    \"aesthetic\": \"clean, minimal, natural light\"\n  },\n  \"technical_notes\": {\n    \"focus_point\": \"eyes and lips\",\n    \"motion\": \"hair shows slight motion, subject otherwise still\",\n    \"post_processing\": \"light retouching, natural finish preserved\"\n  }\n}",
