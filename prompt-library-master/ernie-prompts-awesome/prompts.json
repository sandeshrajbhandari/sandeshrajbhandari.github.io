ape\",\n    \"expression\": \"soft friendly smile, relaxed natural\"\n  },\n  \"accessories\": {\n    \"earbuds\": \"white wireless earbud visible in left ear\",\n    \"necklace\": \"thin gold metal choker necklace\",\n    \"backpack\": \"black backpack with straps visible on shoulders\"\n  },\n  \"wardrobe\": {\n    \"top\": \"pale yellow green ribbed tank top, fitted style, small blue teal dinosaur triceratops embroidered or printed graphic on chest\"\n  },\n  \"setting\": {\n    \"location\": \"outside building in European city, likely Germany\",\n    \"background\": \"blue grey metal door with teal sign reading German text, orange painted wall section on left side\",\n    \"atmosphere\": \"urban European street, casual everyday location\"\n  }\n}",
    "prompt_en": "nano banana pro 🍌\n\n{\n  \"prompt\": \"Casual street style portrait, young woman with platinum white blonde shoulder length wavy hair, soft smile expression looking at camera, light green grey eyes, natural minimal makeup with soft pink lips, white wireless earbud in ear, thin gold choker necklace, wearing pale yellow green ribbed tank top with small blue dinosaur triceratops embroidered graphic, black backpack straps visible on shoulders, standing outside building, blue grey metal door with German text sign reading Notausgang freihalten, orange wall section visible on left, warm golden hour sunlight casting shadow, European urban setting, candid street portrait, natural relaxed mood, 3:4\",\n  \"negative_prompt\": \"indoor studio, heavy makeup, formal clothing, nighttime, harsh lighting, serious expression\",\n  \"style\": \"casual street style photography, candid urban portrait, natural daylight, everyday lifestyle aesthetic\",\n  \"aspect_ratio\": \"3:4\",\n  \"camera\": {\n    \"type\": \"smartphone camera selfie or portrait\",\n    \"angle\": \"front facing, slight angle, eye level\",\n    \"framing\": \"medium close-up, face and upper body\"\n  },\n  \"lighting\": {\n    \"type\": \"natural golden hour sunlight\",\n    \"quality\": \"warm directional side lighting, casting soft shadow on wall\",\n    \"atmosphere\": \"late afternoon golden light\"\n  },\n  \"mood\": \"casual, relaxed, friendly, natural, everyday, approachable\",\n  \"color_palette\": \"platinum blonde, pale yellow green top, blue dinosaur graphic, gold choker, blue grey door, orange wall accent, warm skin tones\",\n  \"subject_features\": {\n    \"hair\": \"platinum white blonde, shoulder length, soft wavy texture, middle parted, natural movement\",\n    \"skin\": \"fair, natural, healthy glow from sunlight\",\n    \"eyes\": \"light green grey, soft friendly gaze at camera\",\n    \"lips\": \"natural soft pink, gentle smile\",\n    \"eyebrows\": \"natural brown, soft groomed