    "prompt": "A doodle-style [subject], naive lines, humorous shape exaggeration",
    "prompt_en": "A doodle-style [subject], naive lines, humorous shape exaggeration",
    "source": "https://x.com/ZHO_ZHO_ZHO/status/1992181199473938774",
