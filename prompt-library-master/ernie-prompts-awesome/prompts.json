    "prompt": "{\"image_prompt_structure\":{\"metadata\":{\"type\":\"Vintage Film Photograph\",\"dimensions\":\"1200x1200px\"},\"style_and_atmosphere\":{\"aesthetic\":\"Dark, grainy vintage film look (e.g., Kodak Portra 800)\",\"mood\":\"Dreamy, melancholic, blurry, atmospheric\",\"effects\":\"Heavy motion blur due to movement and wind, soft focus\"},\"subject\":{\"identity_instruction\":\"Crucial: Do not alter facial features from reference identity. Keep head positioning as is.\",\"appearance\":{\"hair\":\"Long, wavy brown hair, heavily blown about by the wind\"},\"attire\":\"Off-shoulder white knitted top\"},\"action_and_pose\":{\"description\":\"Subject is leaning their upper back backwards out of an open car window while the car is moving.\"},\"setting\":{\"location\":\"Passenger seat window of a vintage car\",\"time\":\"Night\",\"background\":\"Completely blurred streaks of dark city or road lights, illegible shapes due to motion and darkness\",\"environmental_conditions\":\"Extremely windy\"},\"lighting\":{\"description\":\"Low light, likely illuminated by a warm, soft vintage camera flash mixed with ambient streaking streetlights.\"}}}",
    "prompt_en": "{\"image_prompt_structure\":{\"metadata\":{\"type\":\"Vintage Film Photograph\",\"dimensions\":\"1200x1200px\"},\"style_and_atmosphere\":{\"aesthetic\":\"Dark, grainy vintage film look (e.g., Kodak Portra 800)\",\"mood\":\"Dreamy, melancholic, blurry, atmospheric\",\"effects\":\"Heavy motion blur due to movement and wind, soft focus\"},\"subject\":{\"identity_instruction\":\"Crucial: Do not alter facial features from reference identity. Keep head positioning as is.\",\"appearance\":{\"hair\":\"Long, wavy brown hair, heavily blown about by the wind\"},\"attire\":\"Off-shoulder white knitted top\"},\"action_and_pose\":{\"description\":\"Subject is leaning their upper back backwards out of an open car window while the car is moving.\"},\"setting\":{\"location\":\"Passenger seat window of a vintage car\",\"time\":\"Night\",\"background\":\"Completely blurred streaks of dark city or road lights, illegible shapes due to motion and darkness\",\"environmental_conditions\":\"Extremely windy\"},\"lighting\":{\"description\":\"Low light, likely illuminated by a warm, soft vintage camera flash mixed with ambient streaking streetlights.\"}}}",
